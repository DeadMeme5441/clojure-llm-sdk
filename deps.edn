{:paths ["src" "resources"]
 :deps {org.clojure/clojure {:mvn/version "1.12.0"}
        org.clojure/core.async {:mvn/version "1.6.681"}
        metosin/malli {:mvn/version "0.17.0"}
        hato/hato {:mvn/version "1.0.0"}
        cheshire/cheshire {:mvn/version "5.13.0"}}

 :aliases
 {;; Default-safe: exclude live/integration metadata so `clj -M:test`
  ;; never makes a paid API call, even if API keys are present in the
  ;; environment. Live tests live in test/llm/sdk/live_*.clj and carry
  ;; ^:live (or ^:integration) on every deftest.
  :test {:extra-paths ["test" "test-resources"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"
                     "--exclude" ":live"
                     "--exclude" ":integration"]
         :exec-fn cognitect.test-runner.api/test
         :exec-args {:excludes [:live :integration]}}

  ;; Opt-in live runner. Requires ^:live/^:integration metadata so normal
  ;; test runs stay offline. Leaving namespace selection open means callers
  ;; can narrow with `-n llm.sdk.some-live-test` without broadening back to
  ;; every live namespace.
  :live-test {:extra-paths ["test" "test-resources"]
              :extra-deps {io.github.cognitect-labs/test-runner
                           {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
              :main-opts ["-m" "cognitect.test-runner"
                          "--dir" "test"
                          "--include" ":live"
                          "--include" ":integration"]
              :exec-fn cognitect.test-runner.api/test}

  :build {:deps {io.github.clojure/tools.build {:git/tag "v0.10.6" :git/sha "52cf7d6"}}
          :ns-default build}}}
